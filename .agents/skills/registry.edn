{;; Routing rule: match by :summary semantic intent first.
 ;; :triggers are supplemental hints for obvious keyword matches.
 ;; When a task fits a :summary, load the SKILL.md BEFORE editing files.
 ;; logseq-i18n is mandatory for any UI text change — no exceptions.
 :instruction
 "For each request: read :summary for every skill. Load the SKILL.md for any
  skill whose :summary describes the task domain, even if no :trigger matches.
  :triggers are supplemental — they help catch obvious cases; do not rely on
  them as the sole matching signal. logseq-i18n is mandatory: always load it
  before any change that adds, edits, or removes user-facing UI text."

 :skills
 [{:name     "logseq-i18n"
   :path     ".agents/skills/logseq-i18n/SKILL.md"
   :priority :mandatory
   :summary  "Workflow for any task touching user-facing UI text in shipped Logseq:
              adding/renaming/removing keys in src/resources/dicts/, replacing
              hardcoded strings with frontend.context.i18n helpers, updating
              .i18n-lint.toml coverage, or reviewing i18n compliance."
   :triggers ["i18n" "localization" "hardcoded text" "en.edn" "dicts/"
              "notification/show!"]}

  {:name     "logseq-cli"
   :path     ".agents/skills/logseq-cli/SKILL.md"
   :summary  "Operating guide for the logseq CLI tool: graph entity
              inspection/editing, DataScript queries, server lifecycle,
              output format, and command discovery. Load before running
              any logseq command or interpreting its output."
   :triggers ["logseq skill" "logseq server" "logseq --"
              "upsert block" "upsert page" "list node" "list page"]}

  {:name     "logseq-cli-maintenance"
   :path     ".agents/skills/logseq-cli-maintenance/SKILL.md"
   :summary  "Quality and refactoring guide for Logseq CLI source code.
              Apply when improving CLI code structure without changing
              behavior: concern separation (parse/validate/execute/render),
              naming conventions, error code patterns, output formatting,
              and testability."
   :triggers ["refactor CLI" "CLI readability" "CLI maintainability"
              "clean up CLI" "CLI code quality"]}

  {:name     "esm-cjs-risk-scan"
   :path     ".agents/skills/esm-cjs-risk-scan/SKILL.md"
   :summary  "Scan ClojureScript Node/Electron targets for npm packages that
              fail at runtime because they are ESM-only (no require() support).
              Outputs HIGH/MEDIUM/OK risk per package. Run before changing
              Electron/Node deps, after ERR_REQUIRE_ESM errors, or as a
              pre-upgrade compatibility audit."
   :triggers ["ERR_REQUIRE_ESM" "esm-only package" "require() fail"
              "CJS incompatibility" "startup import error"]}

  {:name     "logseq-dependency-upgrade"
   :path     ".agents/skills/logseq-dependency-upgrade/SKILL.md"
   :summary  "Automated audit and upgrade planning across all dependency
              manifests (package.json, deps.edn, bb.edn). Checks latest
              versions, cross-root consistency, OSV vulnerabilities, and
              staleness; generates a batch-ordered upgrade plan."
   :triggers ["OSV vulnerability" "stale package" "dependency upgrade"
              "upgrade plan" "outdated dependency"]}

  {:name     "db-worker-node-repl"
   :path     ".agents/skills/db-worker-node-repl/SKILL.md"
   :summary  "Scripts and steps for starting db-worker-node locally and
              attaching a shadow-cljs CLJS REPL or editor nREPL to the
              :db-worker-node build for interactive ClojureScript debugging."
   :triggers ["db-worker-node" "shadow-cljs REPL" "nREPL" "CLJS REPL"]}]}
